{
    "name": "ueli",
    "description": "Cross-Platform Keystroke Launcher",
    "version": "9.29.0",
    "license": "MIT",
    "author": {
        "email": "oliver.schwendener@proton.me",
        "name": "Oliver Schwendener",
        "url": "https://github.com/oliverschwendener"
    },
    "main": "dist-main/index.js",
    "scripts": {
        "build": "vite build",
        "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
        "dev": "vite",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "package:publish": "electron-builder --config electron-builder.config.js --publish always",
        "package": "electron-builder --config electron-builder.config.js",
        "postinstall": "npm run rebuild",
        "format:check": "oxfmt --check src/**/* docs/**/*.md",
        "format:write": "oxfmt src/**/* docs/**/*.md",
        "rebuild": "electron-builder install-app-deps",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test": "vitest run",
        "typecheck:main": "tsc -p src/main/tsconfig.json --noEmit",
        "typecheck:preload": "tsc -p src/preload/tsconfig.json --noEmit",
        "typecheck:renderer": "tsc -p src/renderer/tsconfig.json --noEmit",
        "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/color": "^4.2.0",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.2",
        "electron": "^43.1.0",
        "electron-builder": "^26.6.0",
        "node-abi": "^4.26.0",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "tree-kill": "^1.2.2",
        "typescript": "^7.0.2",
        "vite": "^8.0.3",
        "vite-plugin-electron": "^0.29.1",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "@fluentui/react-components": "^9.72.9",
        "@fluentui/react-icons": "^2.0.316",
        "better-sqlite3": "^12.8.0",
        "color": "^4.2.3",
        "fast-xml-parser": "^5.5.7",
        "fuse.js": "^7.1.0",
        "fuzzysort": "^3.1.0",
        "i18next": "^26.0.3",
        "mathjs": "^15.2.0",
        "mitt": "^3.0.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-i18next": "^17.0.2",
        "react-router": "^8.2.0",
        "sharp": "^0.35.3",
        "uuid": "^14.0.0"
    }
}
